<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.LifeMelody" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="android:windowBackground">@color/black</item>
        <item name="colorSurfaceContainer">@color/black</item>
        <item name="colorBackground">@color/black</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="colorSurface">@color/dark_gray_surface</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorWelcomeDialog">@color/negrogris</item>
        <item name="colorDialogBackground">@color/darkdialogo</item>
    </style>

    <style name="BottomNavTextStyle">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textFontWeight" tools:targetApi="p">400</item>
        <item name="fontFamily">sans-serif</item> </style>

    <style name="BottomNavigationView.NoSelector" parent="Widget.Material3.BottomNavigationView">
        <item name="itemRippleColor">@android:color/transparent</item>
        <item name="backgroundTint">@color/black</item>
        <item name="elevation">0dp</item>
        <item name="itemIconTint">@color/white</item>
        <item name="itemTextColor">@color/white</item>
        <item name="itemActiveIndicatorStyle">@null</item>
    </style>

    <style name="ToolbarTitleText">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

</resources>