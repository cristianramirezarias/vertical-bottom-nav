<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.LifeMelody" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>

        <item name="android:windowBackground">@color/white</item>
        <item name="colorSurfaceContainer">@color/white</item>
        <item name="colorBackground">@color/white</item>
        <item name="colorOnBackground">@android:color/black</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@android:color/black</item>
        <item name="colorWelcomeDialog">@color/whitepink</item>
        <item name="colorDialogBackground">@color/white</item>
    </style>

    <style name="BottomNavTextStyle">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textFontWeight" tools:targetApi="p">400</item>
        <item name="fontFamily">sans-serif</item> </style>

    <style name="BottomNavigationView.NoSelector" parent="Widget.Material3.BottomNavigationView">
        <item name="itemRippleColor">@android:color/transparent</item>
        <item name="backgroundTint">@color/white</item>
        <item name="elevation">0dp</item>
        <item name="itemIconTint">#000000</item>
        <item name="itemTextColor">#000000</item>
        <item name="itemActiveIndicatorStyle">@null</item>
    </style>

    <style name="AlertDialogCustomStyle" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="buttonBarPositiveButtonStyle">@style/AlertButtonTextColor</item>
        <item name="buttonBarNegativeButtonStyle">@style/AlertButtonTextColor</item>
    </style>

    <style name="ToolbarTitleText">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AlertButtonTextColor" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>
</resources>