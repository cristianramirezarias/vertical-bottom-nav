<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_rounded_dialog">

    <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="@string/sleep_timer_title"
    android:textSize="20sp"
    android:textStyle="bold"
    android:textColor="?attr/colorOnSurface"
    android:layout_marginBottom="16dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.3"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_10_minutes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="@string/option_diez_minutes"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        android:background="?attr/selectableItemBackground"/>

    <TextView
        android:id="@+id/tv_20_minutes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="@string/option_veinte_minutes"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        android:background="?attr/selectableItemBackground"/>

    <TextView
        android:id="@+id/tv_30_minutes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="@string/option_treinta_minutes"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        android:background="?attr/selectableItemBackground"/>

    <TextView
        android:id="@+id/tv_2_hours"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="@string/option_dos_hours"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        android:background="?attr/selectableItemBackground"/>

    <TextView
        android:id="@+id/tv_3_hours"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="@string/option_tres_hours"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        android:background="?attr/selectableItemBackground"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.3" android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_cancel_timer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="@string/option_cancel_timer"
        android:textSize="16sp"
        android:textColor="?attr/colorError"
        android:background="?attr/selectableItemBackground"/>

</LinearLayout>