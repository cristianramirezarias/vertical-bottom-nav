<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceContainer">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/info_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp"
        android:clickable="true"
        android:focusable="true"
        tools:context=".ConfigActivity">

        <FrameLayout
            android:id="@+id/iconTitleContainer"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/circulo_negro_fondo2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/textViewTitle"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iconTitle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_ajustes"
                app:tint="@android:color/white" />
        </FrameLayout>

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/settings_title"
            android:textColor="?attr/colorOnBackground"
            android:textSize="22sp"
            app:layout_constraintStart_toEndOf="@+id/iconTitleContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iconTitleContainer"
            app:layout_constraintBottom_toBottomOf="@+id/iconTitleContainer" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardContact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/colorDialogBackground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_label"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_contact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_email"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:text="lifemelody@krystalshard.com"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_donate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_donate"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:text="@string/donate_label"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_support_ad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_adscore"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:text="@string/support_ad_label"
                    android:textColor="?attr/colorOnSurface" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardLegal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/colorDialogBackground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardContact">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/legal"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_terms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_terms"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:text="@string/terms_and_conditions"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_privacy"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:text="@string/privacy_policy"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPrefs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/colorDialogBackground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardLegal"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/preferencias"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_personalization"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_palette"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:text="@string/personalization_settingstwo"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_sleep_timer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_timer"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:text="@string/sleep_timer_title"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_equalizer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_ecualizador"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:text="@string/equalizer_title"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_volume_control"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_volume"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:text="@string/volumen_title"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tvAdOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_ads"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:text="@string/ads_settings_title"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>